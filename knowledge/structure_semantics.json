{
  "_description": "Structured semantic contract for music-section labels used by support action matching.",
  "_version": "0.2.0",
  "_note": "Fine labels inherit from coarse labels. Hard filters should apply forbidden categories first, then use discouraged categories as score penalties.",
  "_coarse_labels": [
    "bridge",
    "chorus",
    "instrumental",
    "intro",
    "outro",
    "pre_chorus",
    "verse"
  ],
  "_fine_labels": [
    "bridge",
    "chorus",
    "instrumental_break",
    "intro",
    "outro",
    "post_chorus",
    "pre_chorus",
    "pre_chorus_build",
    "solo",
    "verse"
  ],
  "_arrangement_rules": {
    "underground_gei_continuity": {
      "description": "Underground-gei sections should feel like a continuous physical phrase when adjacent high-energy sections support it. Avoid repeatedly starting and stopping underground-gei with ordinary call/MIX in between.",
      "chainable_labels": [
        "chorus",
        "post_chorus",
        "instrumental",
        "instrumental_break"
      ],
      "avoid_patterns": [
        [
          "underground_gei",
          "mix",
          "underground_gei"
        ],
        [
          "underground_gei",
          "rhythmcall",
          "underground_gei"
        ]
      ],
      "policy": "If both neighboring chainable sections strongly support underground-gei, boost underground-gei continuation in the middle chainable section and penalize non-gei interruptions. Use call/MIX as a transition only when the gei chain naturally starts or ends."
    }
  },
  "intro": {
    "level": "coarse_and_fine",
    "inherits": null,
    "coarse_label": "intro",
    "phase": "recognition_opening",
    "description": "The song opening where the audience recognizes the track and settles into the tempo.",
    "vibe": [
      "anticipation",
      "recognition",
      "settling_in"
    ],
    "typical_duration_bars": {
      "min": 4,
      "max": 16
    },
    "allowed_categories": [
      "keepspace",
      "rhythmcall",
      "mix"
    ],
    "discouraged_categories": [
      "underground_gei"
    ],
    "forbidden_categories": [],
    "preferred_action_traits": [
      "simple",
      "iconic",
      "known_intro_tradition"
    ],
    "forbidden_action_traits": [
      "complex_choreography_without_song_tradition"
    ],
    "notes": [
      "Use a signature intro call or short MIX only when the song/context supports it."
    ]
  },
  "verse": {
    "level": "coarse_and_fine",
    "inherits": null,
    "coarse_label": "verse",
    "phase": "lyric_narrative",
    "description": "The narrative body of the song where lyrics and vocal phrasing need space.",
    "vibe": [
      "listening",
      "narrative",
      "moderate_energy"
    ],
    "typical_duration_bars": {
      "min": 8,
      "max": 32
    },
    "allowed_categories": [
      "keepspace",
      "rhythmcall"
    ],
    "discouraged_categories": [
      "mix"
    ],
    "forbidden_categories": [
      "underground_gei"
    ],
    "preferred_action_traits": [
      "light_response",
      "post_phrase_gap",
      "character_specific_only_with_context"
    ],
    "forbidden_action_traits": [
      "dense_mix",
      "large_body_gei"
    ],
    "notes": [
      "Character-specific calls are acceptable only when metadata proves the character/franchise fit."
    ]
  },
  "pre_chorus": {
    "level": "coarse_and_fine",
    "inherits": null,
    "coarse_label": "pre_chorus",
    "phase": "tension_build",
    "description": "The build-up before chorus. Its main musical job is tension accumulation and energy transfer from verse into chorus, so a well-timed MIX can be more appropriate than silence.",
    "vibe": [
      "building",
      "anticipation",
      "rising_energy"
    ],
    "typical_duration_bars": {
      "min": 4,
      "max": 16
    },
    "allowed_categories": [
      "rhythmcall",
      "mix"
    ],
    "discouraged_categories": [
      "keepspace"
    ],
    "forbidden_categories": [
      "underground_gei"
    ],
    "preferred_action_traits": [
      "rising_mix",
      "leadin_mix",
      "exact_bar_fit",
      "chorus_entry_support"
    ],
    "forbidden_action_traits": [
      "large_body_gei",
      "duration_mismatch",
      "contextless_franchise_specific_mix"
    ],
    "notes": [
      "Pre-chorus should usually keep momentum rather than keep space. Prefer MIX or short rhythm calls that pull energy into the chorus.",
      "Do not insert underground gei here. High-risk or franchise-specific MIX still needs matching song/live context."
    ]
  },
  "pre_chorus_build": {
    "level": "fine",
    "inherits": "pre_chorus",
    "coarse_label": "pre_chorus",
    "phase": "late_tension_build",
    "description": "The late pre-chorus ramp immediately before chorus entry. This is often a strong setup point for short, risky, or tradition-specific MIX such as Ie Tiger when the live policy and song context allow it.",
    "vibe": [
      "compressed_build",
      "high_tension",
      "before_release"
    ],
    "typical_duration_bars": {
      "min": 1,
      "max": 8
    },
    "allowed_categories": [
      "mix",
      "rhythmcall"
    ],
    "discouraged_categories": [
      "keepspace"
    ],
    "forbidden_categories": [
      "underground_gei"
    ],
    "preferred_action_traits": [
      "high_tension_mix",
      "ietora_when_allowed",
      "jya_jya_mix",
      "short_leadin",
      "chorus_entry_support"
    ],
    "forbidden_action_traits": [
      "underground_gei",
      "duration_mismatch",
      "artist_banned_ietora"
    ],
    "notes": [
      "Build sections can carry high-risk MIX when they are short, rhythmically locked, and culturally allowed.",
      "Keep space should be a fallback only when the vocal line is too dense, the song is restrained, or context is missing."
    ]
  },
  "chorus": {
    "level": "coarse_and_fine",
    "inherits": null,
    "coarse_label": "chorus",
    "phase": "hook_release",
