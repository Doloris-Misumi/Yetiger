      "rhythmcall",
      "underground_gei"
    ],
    "discouraged_categories": [
      "mix"
    ],
    "forbidden_categories": [],
    "preferred_action_traits": [
      "singable",
      "high_energy",
      "audience_familiar"
    ],
    "forbidden_action_traits": [
      "context_specific_without_metadata"
    ],
    "notes": [
      "Underground gei belongs only in high-energy, sufficiently long, experienced-audience contexts."
    ]
  },
  "post_chorus": {
